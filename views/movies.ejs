<!DOCTYPE html>
<html lang="sk">
<head>
  <%- include("partials/head", { title: "Filmy | FilmRate" }) %>
</head>
<body class="min-h-screen bg-[#05070d] text-white">

  <%- include("partials/navbar") %>

  <main class="mx-auto max-w-7xl px-6 pb-20 pt-14 sm:pt-20">
    <!-- Header -->
    <section>
      <h1 class="max-w-5xl text-4xl font-extrabold leading-tight sm:text-5xl lg:text-7xl">
        Všetky filmy na jednom mieste.
      </h1>

   <!-- Search + filters -->
<form method="GET" action="/movies" class="mt-10">
  <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
    <div class="flex flex-col gap-5 lg:flex-row lg:flex-wrap lg:items-center">
      <div class="w-full lg:min-w-90">
        <div class="relative">
          <span class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-gray-500">
            🔍
          </span>
          <input
            type="text"
            name="q"
            value="<%= search || '' %>"
            placeholder="Hľadaj film..."
            class="w-full rounded-xl border border-white/10 bg-white px-11 py-3 text-lg text-black outline-none transition focus:border-cyan-400"
          />
        </div>
      </div>

      <div class="flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:items-center">
        <span class="text-2xl font-semibold text-white/90">Filtrovať:</span>

        <div class="relative">
          <select
            name="genre"
            class="appearance-none rounded-full border border-white/40 bg-transparent px-6 py-3 pr-12 text-white outline-none"
          >
            <option value="" class="bg-[#111522] text-white">Žáner</option>
            <% genres.forEach(genreItem => { %>
              <option
                value="<%= genreItem.id %>"
                class="bg-[#111522] text-white"
                <%= filters.genre == genreItem.id ? "selected" : "" %>
              >
                <%= genreItem.name %>
              </option>
            <% }) %>
          </select>
          <span class="pointer-events-none absolute right-5 top-1/2 -translate-y-1/2 text-white/70">
            ˅
          </span>
        </div>

        <div class="relative">
          <select
            name="minRating"
            class="appearance-none rounded-full border border-white/40 bg-transparent px-6 py-3 pr-12 text-white outline-none"
          >
            <option value="" class="bg-[#111522] text-white">Hodnotenie</option>
            <option value="5" class="bg-[#111522] text-white" <%= filters.minRating === "5" ? "selected" : "" %>>5+</option>
            <option value="6" class="bg-[#111522] text-white" <%= filters.minRating === "6" ? "selected" : "" %>>6+</option>
            <option value="7" class="bg-[#111522] text-white" <%= filters.minRating === "7" ? "selected" : "" %>>7+</option>
            <option value="8" class="bg-[#111522] text-white" <%= filters.minRating === "8" ? "selected" : "" %>>8+</option>
            <option value="9" class="bg-[#111522] text-white" <%= filters.minRating === "9" ? "selected" : "" %>>9+</option>
          </select>
          <span class="pointer-events-none absolute right-5 top-1/2 -translate-y-1/2 text-white/70">
            ˅
          </span>
        </div>

        <div class="relative">
          <select
            name="runtime"
            class="appearance-none rounded-full border border-white/40 bg-transparent px-6 py-3 pr-12 text-white outline-none"
          >
            <option value="" class="bg-[#111522] text-white">Dĺžka</option>
            <option value="short" class="bg-[#111522] text-white" <%= filters.runtime === "short" ? "selected" : "" %>>Do 90 min</option>
            <option value="medium" class="bg-[#111522] text-white" <%= filters.runtime === "medium" ? "selected" : "" %>>91–120 min</option>
            <option value="long" class="bg-[#111522] text-white" <%= filters.runtime === "long" ? "selected" : "" %>>121+ min</option>
          </select>
          <span class="pointer-events-none absolute right-5 top-1/2 -translate-y-1/2 text-white/70">
            ˅
          </span>
        </div>

        <div class="relative">
          <select
            name="sort"
            class="appearance-none rounded-full border border-white/40 bg-transparent px-6 py-3 pr-12 text-white outline-none"
          >
            <option value="popularity.desc" class="bg-[#111522] text-white" <%= filters.sort === "popularity.desc" ? "selected" : "" %>>Popularita ↓</option>
            <option value="popularity.asc" class="bg-[#111522] text-white" <%= filters.sort === "popularity.asc" ? "selected" : "" %>>Popularita ↑</option>
            <option value="primary_release_date.desc" class="bg-[#111522] text-white" <%= filters.sort === "primary_release_date.desc" ? "selected" : "" %>>Najnovšie</option>
            <option value="primary_release_date.asc" class="bg-[#111522] text-white" <%= filters.sort === "primary_release_date.asc" ? "selected" : "" %>>Najstaršie</option>
            <option value="vote_average.desc" class="bg-[#111522] text-white" <%= filters.sort === "vote_average.desc" ? "selected" : "" %>>Rating ↓</option>
            <option value="vote_average.asc" class="bg-[#111522] text-white" <%= filters.sort === "vote_average.asc" ? "selected" : "" %>>Rating ↑</option>
          </select>
          <span class="pointer-events-none absolute right-5 top-1/2 -translate-y-1/2 text-white/70">
            ˅
          </span>
        </div>

        <div class="w-full sm:w-auto">
          <input
            type="number"
            name="year"
            min="1900"
            max="2100"
            value="<%= filters.year || '' %>"
            placeholder="Rok"
            class="w-full rounded-full border border-white/40 bg-transparent px-6 py-3 text-white outline-none placeholder:text-white/60 sm:w-32"
          />
        </div>

        <button
          type="submit"
          class="inline-flex items-center justify-center rounded-lg bg-[#00c950]/90 px-6 py-3 text-lg font-semibold text-white transition hover:bg-[#00c950]/80"
        >
          Použiť filtre
        </button>

        <a
          href="/movies"
          class="inline-flex items-center justify-center rounded-lg border border-white/20 bg-white/5 px-6 py-3 text-lg font-medium text-white transition hover:bg-white/10"
        >
          Reset
        </a>
      </div>
    </div>
  </div>
</form>

      <div class="mt-10 h-px w-full bg-white/30"></div>
    </section>

    <!-- Movies list -->
    <section class="mt-12 space-y-8">
    <% movies.forEach(movie => { %>
  <article class="overflow-hidden rounded-4xl bg-[#171c29] shadow-[0_10px_40px_rgba(0,0,0,0.35)]">
    <div class="flex flex-col md:flex-row">
      <div class="w-full md:w-55">
        <img
          src="<%= movie.poster || 'https://placehold.co/220x300?text=Poster' %>"
          alt="Poster filmu <%= movie.title %>"
          class="h-full w-full object-cover"
        />
      </div>

      <div class="flex flex-1 flex-col justify-between gap-6 p-6 md:flex-row md:items-stretch md:p-8">
        <div class="flex-1">
          <h2 class="text-2xl font-bold sm:text-4xl"><%= movie.title %></h2>

          <div class="mt-5 flex flex-wrap items-center gap-x-6 gap-y-2 text-base text-gray-300 sm:text-xl">
            <span><%= movie.releaseDate || "—" %></span>
            <span class="text-yellow-400">⭐ <%= Number(movie.rating || 0).toFixed(1) %>/10</span>
          </div>

          <p class="mt-6 max-w-3xl text-base leading-7 text-gray-200 sm:text-2xl sm:leading-9">
            <%= movie.overview || "Bez popisu." %>
          </p>
        </div>

        <div class="hidden w-px bg-white/40 md:block"></div>

        <div class="flex items-center justify-end md:min-w-22.5 md:justify-center">
          <a href="/movies/<%= movie.id %>" class="text-5xl text-white transition hover:translate-x-1">→</a>
        </div>
      </div>
    </div>
  </article>
<% }) %>
    </section>

    <!-- Load more -->
<% if (currentPage < totalPages) { %>
  <section class="mt-14 flex justify-center">
    <a
      href="/movies?<%= new URLSearchParams({
        q: search || '',
        genre: filters.genre || '',
        minRating: filters.minRating || '',
        runtime: filters.runtime || '',
        sort: filters.sort || 'popularity.desc',
        year: filters.year || '',
        page: String(currentPage + 1)
      }).toString() %>"
      class="rounded-full border border-white px-10 py-4 text-xl font-medium text-white transition hover:bg-white hover:text-black sm:px-20"
    >
      Načítať viac ↓
    </a>
  </section>
<% } %>
  </main>

  <%- include("partials/footer") %>

</body>
</html>