<!DOCTYPE html>
<html lang="sk">
<head>
  <%- include("partials/head", { title: `${movie.title} | FilmRate` }) %>
</head>
<body class="min-h-screen bg-[#05070d] text-white">

  <%- include("partials/navbar") %>

  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="<%= movie.backdrop %>"
        alt="Backdrop filmu <%= movie.title %>"
        class="h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-black/75"></div>
      <div class="absolute inset-0 bg-linear-to-b from-black/55 via-black/45 to-[#05070d]"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-6 pb-14 pt-12 sm:pb-18 sm:pt-16">
      <div class="flex flex-col gap-10 lg:flex-row lg:items-start lg:justify-between">
        <div class="flex-1">
          <div class="flex flex-col gap-4">
            <div class="flex flex-col gap-3 lg:flex-row lg:flex-wrap lg:items-center">
              <h1 class="text-4xl font-extrabold leading-tight sm:text-5xl lg:text-7xl">
                <%= movie.title %>
              </h1>

              <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-lg text-gray-300 sm:text-2xl">
                <span>• <%= movie.director %></span>
                <span>• <%= movie.duration %></span>
                <span>• <%= movie.year %></span>
              </div>
            </div>

            <div class="mt-4 flex flex-col gap-8 md:flex-row md:items-start">
              <div class="w-full max-w-64 shrink-0">
                <img
                  src="<%= movie.poster %>"
                  alt="Poster filmu <%= movie.title %>"
                  class="h-full w-full rounded-sm object-cover shadow-[0_10px_40px_rgba(0,0,0,0.45)]"
                />
              </div>

              <div class="max-w-3xl pt-1">
                <p class="text-lg leading-8 text-gray-200 sm:text-2xl sm:leading-10">
                  <%= movie.description %>
                </p>
              </div>
            </div>
          </div>
        </div>

        <aside class="w-full max-w-90 shrink-0">
          <div class="rounded-4xl bg-[#171c29]/95 p-8 shadow-[0_10px_40px_rgba(0,0,0,0.35)] backdrop-blur-sm">
            <div class="mb-10 flex items-center gap-4">
              <img
                src="/images/logo.png"
                alt="FilmRate logo"
                class="h-14 w-auto object-contain"
              />
              <span class="text-3xl font-extrabold text-white">
                Film<span class="text-green-500">Rate</span>
              </span>
            </div>

            <div class="text-center">
              <p class="text-6xl font-extrabold text-white sm:text-7xl"><%= movie.rating %>/10</p>
              <div class="mx-auto mt-4 h-px w-full max-w-44 bg-white/40"></div>
            </div>

            <div class="mt-8">
              <a
                href="/movies/<%= movie.id %>/review/create"
                class="inline-flex w-full items-center justify-center rounded-lg bg-[#738b58] px-6 py-4 text-2xl font-semibold text-white transition hover:bg-[#829d64]"
              >
                Vytvoriť recenziu
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="bg-black px-6 py-12">
    <div class="mx-auto max-w-7xl">
      <h2 class="text-4xl font-extrabold sm:text-5xl">Účinkujú</h2>

      <div class="mt-8 grid grid-cols-2 gap-6 sm:grid-cols-3 lg:grid-cols-6">
        <% movie.cast.forEach(actor => { %>
          <article class="overflow-hidden bg-[#171c29]">
            <img
              src="<%= actor.image %>"
              alt="Fotografia herca <%= actor.name %>"
              class="aspect-4/5 h-full w-full object-cover"
            />
            <div class="p-3">
              <h3 class="text-base font-bold text-white"><%= actor.name %></h3>
              <p class="text-sm text-gray-300"><%= actor.role %></p>
            </div>
          </article>
        <% }) %>
      </div>
    </div>
  </section>

<section class="bg-[#07101d] px-6 py-12 sm:py-14">
  <div class="mx-auto max-w-7xl">
    <h2 class="text-5xl font-extrabold sm:text-6xl">Recenzie</h2>

    <% if (movie.reviews.length === 0) { %>
      <div class="mt-10 rounded-4xl bg-[#171c29] p-8 text-center shadow-[0_10px_40px_rgba(0,0,0,0.35)]">
        <h3 class="text-3xl font-bold">Zatiaľ tu nie sú žiadne recenzie</h3>
        <p class="mt-4 text-lg text-gray-300">
          Buď prvý, kto pridá recenziu k tomuto filmu.
        </p>

        <div class="mt-8">
          <a
            href="/movies/<%= movie.id %>/review/create"
            class="inline-flex items-center justify-center rounded-lg bg-[#738b58] px-8 py-4 text-xl font-semibold text-white transition hover:bg-[#829d64]"
          >
            Vytvoriť recenziu
          </a>
        </div>
      </div>
    <% } %>

    <div class="mt-10 space-y-8">
      <% movie.reviews.forEach(review => { %>
        <article class="rounded-4xl bg-[#171c29] p-6 shadow-[0_10px_40px_rgba(0,0,0,0.35)] sm:p-8">
          <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
            <div class="flex items-center gap-3">
              <img
                src="<%= review.avatar_url || 'https://placehold.co/48x48?text=AV' %>"
                alt="Avatar používateľa <%= review.username %>"
                class="h-12 w-12 rounded-full object-cover"
              />
              <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
               <a
  href="/users/<%= review.username %>"
  class="text-lg font-semibold text-white transition hover:text-[#00c950]"
>
  <%= review.username %>
</a>
                <span class="text-xl text-gray-400">·</span>
                <span class="text-xl text-gray-400">
                  <%= new Date(review.created_at).toLocaleDateString("sk-SK") %>
                </span>
              </div>
            </div>

            <div class="text-left sm:text-right">
              <span class="text-3xl font-semibold text-white">⭐ <%= review.rating %>/10</span>
            </div>
          </div>

          <% if (review.title) { %>
            <h3 class="mt-6 text-2xl font-bold sm:text-3xl"><%= review.title %></h3>
          <% } %>

          <p class="mt-6 text-base leading-7 text-gray-300 sm:text-2xl sm:leading-8">
            <%= review.review_text %>
          </p>

          <% if (review.contains_spoilers) { %>
            <p class="mt-4 inline-block rounded-full bg-red-500/15 px-4 py-2 text-sm font-medium text-red-300">
              Obsahuje spoilery
            </p>
          <% } %>

          <div class="mt-8 flex items-center justify-end gap-4 text-white">
  <% if (user && user.id !== review.user_id) { %>
    <form action="/reviews/<%= review.id %>/vote" method="POST">
      <input type="hidden" name="voteType" value="helpful" />
      <button class="flex items-center gap-2 text-2xl transition hover:text-gray-300">
        <span class="cursor-pointer">👍</span>
        <span class="text-xl"><%= review.helpful_count %></span>
      </button>
    </form>

    <form action="/reviews/<%= review.id %>/vote" method="POST">
      <input type="hidden" name="voteType" value="not_helpful" />
      <button class="flex items-center gap-2 text-2xl transition hover:text-gray-300">
        <span class="cursor-pointer">👎</span>
        <span class="text-xl"><%= review.not_helpful_count %></span>
      </button>
    </form>
  <% } else { %>
    <div class="flex items-center gap-2 text-2xl text-white/80">
      <span class="cursor-pointer">👍</span>
      <span class="text-xl"><%= review.helpful_count %></span>
    </div>

    <div class="flex items-center gap-2 text-2xl text-white/80">
      <span class="cursor-pointer">👎</span>
      <span class="text-xl"><%= review.not_helpful_count %></span>
    </div>
  <% } %>

  <button class="flex items-center gap-2 text-2xl transition hover:text-gray-300">
    <span>💬</span>
    <span class="text-xl">0</span>
  </button>
</div>
        </article>
      <% }) %>
    </div>
  </div>
</section>

  <%- include("partials/footer") %>

</body>
</html>