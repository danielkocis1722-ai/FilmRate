<!DOCTYPE html>
<html lang="sk">
  <head>
    <%- include("partials/head", { title: "Komentáre | FilmRate" }) %>
  </head>
  <body class="min-h-screen bg-[#05070d] text-white">
    <%- include("partials/navbar") %>

    <main class="mx-auto max-w-4xl px-6 py-14">
      <!-- REVIEW -->
      <section class="rounded-4xl bg-[#171c29] p-6 shadow-xl">
        <h2 class="text-2xl font-bold"><%= review.title || "Bez nadpisu" %></h2>
        <p class="mt-2 text-gray-400">
          <%= review.username %> · <%= new
          Date(review.created_at).toLocaleDateString("sk-SK") %>
        </p>

        <p class="mt-4 text-lg">⭐ <%= review.rating %>/10</p>

        <p class="mt-6 text-gray-300"><%= review.review_text %></p>
      </section>

      <!-- COMMENTS -->
      <section class="mt-10">
        <h3 class="text-3xl font-bold">Komentáre</h3>

        <div class="mt-6 space-y-4">
          <% if (comments.length === 0) { %>
          <p class="text-gray-400">Zatiaľ žiadne komentáre.</p>
          <% } %>

          <% comments.forEach(comment => { %>
          <div class="rounded-xl bg-[#171c29] p-4">
            <p class="text-sm text-gray-400">
              <a
                href="/users/<%= encodeURIComponent(comment.username) %>"
                class="font-medium text-[#00c950] transition hover:opacity-80"
              >
                <%= comment.username %>
              </a>
              <span class="text-gray-400">·</span>
              <%= new Date(comment.created_at).toLocaleDateString("sk-SK") %>
            </p>

            <p class="mt-2"><%= comment.comment_text %></p>
          </div>
          <% }) %>
        </div>
      </section>

      <!-- ADD COMMENT -->
      <% if (user) { %>
      <section class="mt-10">
        <form method="POST" action="/reviews/<%= review.id %>/comments">
          <textarea
            name="commentText"
            rows="3"
            placeholder="Napíš komentár..."
            class="w-full rounded-xl bg-[#171c29] p-4 text-white outline-none"
          ></textarea>

          <button
            type="submit"
            class="mt-4 rounded-lg bg-[#00c950] px-6 py-3 font-semibold"
          >
            Pridať komentár
          </button>
        </form>
      </section>
      <% } else { %>
      <p class="mt-10 text-gray-400">
        Pre pridanie komentára sa musíš prihlásiť.
      </p>
      <% } %>
    </main>

    <%- include("partials/footer") %>
  </body>
</html>
