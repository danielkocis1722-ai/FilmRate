<!DOCTYPE html>
<html lang="sk">
<head>
  <%- include("partials/head", { title: "Recenzie | FilmRate" }) %>
</head>
<body class="min-h-screen bg-[#05070d] text-white">

  <%- include("partials/navbar") %>

  <main class="mx-auto max-w-7xl px-6 pb-20 pt-14 sm:pt-20">
    <section>
      <h1 class="max-w-6xl text-4xl font-extrabold leading-tight sm:text-5xl lg:text-7xl">
        Všetky recenzie na jednom mieste.
      </h1>
<form method="GET" action="/reviews" class="mt-10">
  <div class="flex flex-col gap-20 lg:flex-row lg:items-end lg:justify-between">
    <!-- LEFT SIDE -->
    <div class="flex min-w-0 flex-1 flex-col gap-4">
      <div class="min-w-0">
        <div class="relative">
          <span class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-gray-500">
            🔍
          </span>
          <input
            type="text"
            name="q"
            value="<%= typeof search !== 'undefined' ? search : '' %>"
            placeholder="Hľadaj film..."
            class="w-full rounded-xl border border-white/10 bg-white px-11 py-3 text-lg text-black outline-none transition focus:border-cyan-400"
          />
        </div>
      </div>

      <div class="flex flex-wrap items-center gap-4">
        <button
          type="submit"
          class="inline-flex items-center justify-center rounded-lg bg-[#00c950]/90 px-6 py-3 text-lg font-semibold text-white transition hover:bg-[#00c950]/80"
        >
          Použiť filtre
        </button>

        <a
          href="/reviews"
          class="inline-flex items-center justify-center rounded-lg border border-white/20 bg-white/5 px-6 py-3 text-lg font-medium text-white transition hover:bg-white/10"
        >
          Reset
        </a>
      </div>
    </div>

    <!-- RIGHT SIDE -->
    <div class="flex flex-col gap-4 lg:shrink-0 lg:items-end">
      <div class="flex flex-wrap items-center gap-4 lg:justify-end">
        <span class="text-2xl font-semibold text-white/90">Filtrovať:</span>

        <div class="relative">
          <select
            name="spoilers"
            class="appearance-none rounded-full border border-white/40 bg-transparent px-6 py-3 pr-12 text-white outline-none"
          >
            <option value="no" class="bg-[#111522] text-white" <%= spoilers === "no" ? "selected" : "" %>>
              Bez spoilerov
            </option>
            <option value="yes" class="bg-[#111522] text-white" <%= spoilers === "yes" ? "selected" : "" %>>
              So spoilermi
            </option>
            <option value="all" class="bg-[#111522] text-white" <%= spoilers === "all" ? "selected" : "" %>>
              Všetky recenzie
            </option>
          </select>
          <span class="pointer-events-none absolute right-5 top-1/2 -translate-y-1/2 text-white/70">˅</span>
        </div>

        <div class="relative">
            <select
            name="minRating"
            class="appearance-none rounded-full border border-white/40 bg-transparent px-6 py-3 pr-12 text-white outline-none"
          >
            <option value="" class="bg-[#111522] text-white" <%= !minRating ? "selected" : "" %>>
              Hodnotenie
            </option>
            <option value="1" class="bg-[#111522] text-white" <%= minRating === "1" ? "selected" : "" %>>1+</option>
            <option value="2" class="bg-[#111522] text-white" <%= minRating === "2" ? "selected" : "" %>>2+</option>
            <option value="3" class="bg-[#111522] text-white" <%= minRating === "3" ? "selected" : "" %>>3+</option>
            <option value="4" class="bg-[#111522] text-white" <%= minRating === "4" ? "selected" : "" %>>4+</option>
            <option value="5" class="bg-[#111522] text-white" <%= minRating === "5" ? "selected" : "" %>>5+</option>
            <option value="6" class="bg-[#111522] text-white" <%= minRating === "6" ? "selected" : "" %>>6+</option>
            <option value="7" class="bg-[#111522] text-white" <%= minRating === "7" ? "selected" : "" %>>7+</option>
            <option value="8" class="bg-[#111522] text-white" <%= minRating === "8" ? "selected" : "" %>>8+</option>
            <option value="9" class="bg-[#111522] text-white" <%= minRating === "9" ? "selected" : "" %>>9+</option>
            </select>
          <span class="pointer-events-none absolute right-5 top-1/2 -translate-y-1/2 text-white/70">˅</span>
        </div>
      </div>

      <a
        href="/reviews/create"
        class="inline-flex items-center justify-center rounded-lg bg-[#00c950]/90 px-8 py-4 text-xl font-semibold text-white transition hover:bg-[#00c950]/80"
      >
        Vytvoriť recenziu
      </a>
    </div>
  </div>
</form>
      <div class="mt-10 h-px w-full bg-white/30"></div>
    </section>

   <section id="reviews-list" class="mt-12 space-y-10">
      <% if (reviews.length === 0) { %>
        <div class="rounded-4xl bg-[#171c29] p-8 text-center shadow-[0_10px_40px_rgba(0,0,0,0.35)]">
          <h2 class="text-3xl font-bold">Zatiaľ tu nie sú žiadne recenzie</h2>
          <p class="mt-4 text-lg text-gray-300">
  <% if (search || spoilers !== "no" || minRating) { %>
    Skús zmeniť vyhľadávanie alebo filtre.
  <% } else { %>
    Buď prvý, kto pridá recenziu.
  <% } %>
</p>
        </div>
      <% } %>

      <% reviews.forEach(review => { %>
     <%- include("partials/review-card", { review, user }) %>
      <% }) %>
    </section>

    <% if (currentPage < totalPages) { %>
  <section class="mt-14 flex justify-center">
    <button
      id="load-more-reviews-btn"
      type="button"
      data-current-page="<%= currentPage %>"
      data-total-pages="<%= totalPages %>"
      data-q="<%= search || '' %>"
      data-spoilers="<%= spoilers || 'no' %>"
      data-min-rating="<%= minRating || '' %>"
      class="rounded-full border border-white px-10 py-4 text-xl font-medium text-white transition hover:bg-white hover:text-black sm:px-20"
    >
      Načítať viac ↓
    </button>
  </section>
<% } %>
  </main>

  <%- include("partials/footer") %>





<script>
  const loadMoreReviewsBtn = document.getElementById("load-more-reviews-btn");
  const reviewsList = document.getElementById("reviews-list");

  function escapeHtml(str) {
    return String(str)
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#039;");
  }

  function createReviewCard(review, currentUserId) {
    const createdAt = new Date(review.created_at).toLocaleDateString("sk-SK");
    const avatar = review.avatar_url || "https://placehold.co/48x48?text=AV";
    const moviePoster =
      review.moviePoster || "https://placehold.co/180x260?text=Poster";
    const movieTitle = review.movieTitle || "Neznámy film";
    const reviewTitle = review.title || "Bez nadpisu";
    const helpfulCount = Number(review.helpful_count || 0);
    const notHelpfulCount = Number(review.not_helpful_count || 0);
    const isOwnReview =
      currentUserId && Number(currentUserId) === Number(review.user_id);

    return `
      <article class="rounded-4xl bg-[#171c29] p-5 shadow-[0_10px_40px_rgba(0,0,0,0.35)] sm:p-7">
        <div class="flex flex-col gap-6 md:flex-row">
          <div class="w-full md:w-36">
            <a href="/movies/${review.tmdb_movie_id}">
              <img
                src="${moviePoster}"
                alt="Poster filmu ${escapeHtml(movieTitle)}"
                class="h-full w-full rounded-2xl object-cover"
              />
            </a>
          </div>

          <div class="flex-1">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
              <div class="flex items-center gap-3">
                <img
                  src="${avatar}"
                  alt="Avatar používateľa ${escapeHtml(review.username)}"
                  class="h-12 w-12 rounded-full object-cover"
                />
                <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                  <a
                    href="/users/${encodeURIComponent(review.username)}"
                    class="text-lg font-semibold text-white transition hover:text-[#00c950]"
                  >
                    ${escapeHtml(review.username)}
                  </a>
                  <span class="text-lg text-gray-400">·</span>
                  <span class="text-lg text-gray-400">${createdAt}</span>
                </div>
              </div>
            </div>

            <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2">
              <h2 class="text-3xl font-bold sm:text-4xl">${escapeHtml(reviewTitle)}</h2>
              <span class="hidden text-4xl text-gray-400 sm:inline">|</span>
              <span class="text-2xl font-semibold text-white sm:text-3xl">
                ⭐ ${review.rating}/10
              </span>
            </div>

            <p class="mt-3 text-lg font-medium text-[#00c950] sm:text-xl">
              <a href="/movies/${review.tmdb_movie_id}" class="transition hover:opacity-80">
                ${escapeHtml(movieTitle)}
              </a>
            </p>

            <p class="mt-5 max-w-5xl text-base leading-7 text-gray-300 sm:text-2xl sm:leading-8">
              ${escapeHtml(review.review_text)}
            </p>

            ${
              review.contains_spoilers
                ? `
                  <p class="mt-4 inline-block rounded-full bg-red-500/15 px-4 py-2 text-sm font-medium text-red-300">
                    Obsahuje spoilery
                  </p>
                `
                : ""
            }

            <div
              class="mt-8 flex items-center justify-end gap-4 text-white"
              data-review-id="${review.id}"
            >
              ${
                !isOwnReview && currentUserId
                  ? `
                    <button
                      type="button"
                      data-vote-button="helpful"
                      class="flex items-center gap-2 text-2xl transition hover:text-gray-300"
                    >
                      <span class="cursor-pointer">👍</span>
                      <span class="text-xl" data-helpful-count>${helpfulCount}</span>
                    </button>

                    <button
                      type="button"
                      data-vote-button="not_helpful"
                      class="flex items-center gap-2 text-2xl transition hover:text-gray-300"
                    >
                      <span class="cursor-pointer">👎</span>
                      <span class="text-xl" data-not-helpful-count>${notHelpfulCount}</span>
                    </button>
                  `
                  : `
                    <div class="flex items-center gap-2 text-2xl text-white/80">
                      <span class="cursor-pointer">👍</span>
                      <span class="text-xl" data-helpful-count>${helpfulCount}</span>
                    </div>

                    <div class="flex items-center gap-2 text-2xl text-white/80">
                      <span class="cursor-pointer">👎</span>
                      <span class="text-xl" data-not-helpful-count>${notHelpfulCount}</span>
                    </div>
                  `
              }

      <a 
  href="/reviews/${review.id}/comments"
  class="flex items-center gap-2 text-2xl transition hover:text-gray-300"
>
  <span>💬</span>
  <span class="text-xl">${Number(review.comments_count || 0)}</span>
</a>
            </div>
          </div>
        </div>
      </article>
    `;
  }

  async function loadMoreReviews() {
    if (!loadMoreReviewsBtn) return;

    const currentPage = Number(loadMoreReviewsBtn.dataset.currentPage);
    const totalPages = Number(loadMoreReviewsBtn.dataset.totalPages);

    if (currentPage >= totalPages) {
      loadMoreReviewsBtn.remove();
      return;
    }

    loadMoreReviewsBtn.disabled = true;
    loadMoreReviewsBtn.textContent = "Načítavam...";

    const params = new URLSearchParams({
      q: loadMoreReviewsBtn.dataset.q || "",
      spoilers: loadMoreReviewsBtn.dataset.spoilers || "no",
      minRating: loadMoreReviewsBtn.dataset.minRating || "",
      page: String(currentPage + 1),
    });

    try {
      const response = await fetch(`/api/reviews?${params.toString()}`);
      const data = await response.json();

      if (!response.ok) {
        throw new Error(data.error || "Chyba pri načítaní recenzií.");
      }

      const currentUserId = "<%= user ? user.id : '' %>";
      const html = data.reviews
        .map((review) => createReviewCard(review, currentUserId))
        .join("");

      reviewsList.insertAdjacentHTML("beforeend", html);

      loadMoreReviewsBtn.dataset.currentPage = String(data.currentPage);

      if (data.currentPage >= data.totalPages) {
        loadMoreReviewsBtn.remove();
      } else {
        loadMoreReviewsBtn.disabled = false;
        loadMoreReviewsBtn.textContent = "Načítať viac ↓";
      }
    } catch (error) {
      console.error(error);
      loadMoreReviewsBtn.disabled = false;
      loadMoreReviewsBtn.textContent = "Skús znova";
    }
  }

  async function sendVote(reviewId, voteType, wrapper, button) {
    try {
      button.disabled = true;

      const response = await fetch(`/api/reviews/${reviewId}/vote`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ voteType }),
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data.error || "Chyba pri hlasovaní.");
      }

      const helpfulCountEl = wrapper.querySelector("[data-helpful-count]");
      const notHelpfulCountEl = wrapper.querySelector("[data-not-helpful-count]");

      if (helpfulCountEl) {
        helpfulCountEl.textContent = data.helpfulCount;
      }

      if (notHelpfulCountEl) {
        notHelpfulCountEl.textContent = data.notHelpfulCount;
      }
    } catch (error) {
      console.error(error);
      alert(error.message || "Chyba pri hlasovaní.");
    } finally {
      button.disabled = false;
    }
  }

  if (loadMoreReviewsBtn) {
    loadMoreReviewsBtn.addEventListener("click", loadMoreReviews);
  }

  document.addEventListener("click", (event) => {
    const voteButton = event.target.closest("[data-vote-button]");
    if (!voteButton) return;

    const wrapper = voteButton.closest("[data-review-id]");
    if (!wrapper) return;

    const reviewId = wrapper.dataset.reviewId;
    const voteType = voteButton.dataset.voteButton;

    sendVote(reviewId, voteType, wrapper, voteButton);
  });
</script>
</body>
</html>