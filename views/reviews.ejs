<!DOCTYPE html>
<html lang="sk">
<head>
  <%- include("partials/head", { title: "Recenzie | FilmRate" }) %>
</head>
<body class="min-h-screen bg-[#05070d] text-white">

  <%- include("partials/navbar") %>

  <main class="mx-auto max-w-7xl px-6 pb-20 pt-14 sm:pt-20">
    <section>
      <h1 class="max-w-6xl text-4xl font-extrabold leading-tight sm:text-5xl lg:text-7xl">
        Všetky recenzie na jednom mieste.
      </h1>
<form method="GET" action="/reviews" class="mt-10">
  <div class="flex flex-col gap-20 lg:flex-row lg:items-end lg:justify-between">
    <!-- LEFT SIDE -->
    <div class="flex min-w-0 flex-1 flex-col gap-4">
      <div class="min-w-0">
        <div class="relative">
          <span class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-gray-500">
            🔍
          </span>
          <input
            type="text"
            name="q"
            value="<%= typeof search !== 'undefined' ? search : '' %>"
            placeholder="Hľadaj film..."
            class="w-full rounded-xl border border-white/10 bg-white px-11 py-3 text-lg text-black outline-none transition focus:border-cyan-400"
          />
        </div>
      </div>

      <div class="flex flex-wrap items-center gap-4">
        <button
          type="submit"
          class="inline-flex items-center justify-center rounded-lg bg-[#00c950]/90 px-6 py-3 text-lg font-semibold text-white transition hover:bg-[#00c950]/80"
        >
          Použiť filtre
        </button>

        <a
          href="/reviews"
          class="inline-flex items-center justify-center rounded-lg border border-white/20 bg-white/5 px-6 py-3 text-lg font-medium text-white transition hover:bg-white/10"
        >
          Reset
        </a>
      </div>
    </div>

    <!-- RIGHT SIDE -->
    <div class="flex flex-col gap-4 lg:shrink-0 lg:items-end">
      <div class="flex flex-wrap items-center gap-4 lg:justify-end">
        <span class="text-2xl font-semibold text-white/90">Filtrovať:</span>

        <div class="relative">
          <select
            name="spoilers"
            class="appearance-none rounded-full border border-white/40 bg-transparent px-6 py-3 pr-12 text-white outline-none"
          >
            <option value="no" class="bg-[#111522] text-white" <%= spoilers === "no" ? "selected" : "" %>>
              Bez spoilerov
            </option>
            <option value="yes" class="bg-[#111522] text-white" <%= spoilers === "yes" ? "selected" : "" %>>
              So spoilermi
            </option>
            <option value="all" class="bg-[#111522] text-white" <%= spoilers === "all" ? "selected" : "" %>>
              Všetky recenzie
            </option>
          </select>
          <span class="pointer-events-none absolute right-5 top-1/2 -translate-y-1/2 text-white/70">˅</span>
        </div>

        <div class="relative">
            <select
            name="minRating"
            class="appearance-none rounded-full border border-white/40 bg-transparent px-6 py-3 pr-12 text-white outline-none"
          >
            <option value="" class="bg-[#111522] text-white" <%= !minRating ? "selected" : "" %>>
              Hodnotenie
            </option>
            <option value="1" class="bg-[#111522] text-white" <%= minRating === "1" ? "selected" : "" %>>1+</option>
            <option value="2" class="bg-[#111522] text-white" <%= minRating === "2" ? "selected" : "" %>>2+</option>
            <option value="3" class="bg-[#111522] text-white" <%= minRating === "3" ? "selected" : "" %>>3+</option>
            <option value="4" class="bg-[#111522] text-white" <%= minRating === "4" ? "selected" : "" %>>4+</option>
            <option value="5" class="bg-[#111522] text-white" <%= minRating === "5" ? "selected" : "" %>>5+</option>
            <option value="6" class="bg-[#111522] text-white" <%= minRating === "6" ? "selected" : "" %>>6+</option>
            <option value="7" class="bg-[#111522] text-white" <%= minRating === "7" ? "selected" : "" %>>7+</option>
            <option value="8" class="bg-[#111522] text-white" <%= minRating === "8" ? "selected" : "" %>>8+</option>
            <option value="9" class="bg-[#111522] text-white" <%= minRating === "9" ? "selected" : "" %>>9+</option>
            </select>
          <span class="pointer-events-none absolute right-5 top-1/2 -translate-y-1/2 text-white/70">˅</span>
        </div>
      </div>

      <a
        href="/reviews/create"
        class="inline-flex items-center justify-center rounded-lg bg-[#00c950]/90 px-8 py-4 text-xl font-semibold text-white transition hover:bg-[#00c950]/80"
      >
        Vytvoriť recenziu
      </a>
    </div>
  </div>
</form>
      <div class="mt-10 h-px w-full bg-white/30"></div>
    </section>

    <section class="mt-12 space-y-10">
      <% if (reviews.length === 0) { %>
        <div class="rounded-4xl bg-[#171c29] p-8 text-center shadow-[0_10px_40px_rgba(0,0,0,0.35)]">
          <h2 class="text-3xl font-bold">Zatiaľ tu nie sú žiadne recenzie</h2>
          <p class="mt-4 text-lg text-gray-300">
  <% if (search || spoilers !== "no" || minRating) { %>
    Skús zmeniť vyhľadávanie alebo filtre.
  <% } else { %>
    Buď prvý, kto pridá recenziu.
  <% } %>
</p>
        </div>
      <% } %>

      <% reviews.forEach(review => { %>
        <article class="rounded-4xl bg-[#171c29] p-5 shadow-[0_10px_40px_rgba(0,0,0,0.35)] sm:p-7">
          <div class="flex flex-col gap-6 md:flex-row">
            <div class="w-full md:w-36">
              <a href="/movies/<%= review.tmdb_movie_id %>">
  <img
    src="<%= review.moviePoster %>"
    alt="Poster filmu <%= review.movieTitle %>"
    class="h-full w-full rounded-2xl object-cover"
  />
</a>
            </div>

            <div class="flex-1">
              <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                <div class="flex items-center gap-3">
                  <img
                    src="<%= review.avatar_url || 'https://placehold.co/48x48?text=AV' %>"
                    alt="Placeholder avatar používateľa <%= review.username %>"
                    class="h-12 w-12 rounded-full object-cover"
                  />
                  <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                    <a
  href="/users/<%= review.username %>"
  class="text-lg font-semibold text-white transition hover:text-[#00c950]"
>
  <%= review.username %>
</a>
                    <span class="text-lg text-gray-400">·</span>
                    <span class="text-lg text-gray-400">
                      <%= new Date(review.created_at).toLocaleDateString("sk-SK") %>
                    </span>
                  </div>
                </div>
              </div>

              <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2">
                <h2 class="text-3xl font-bold sm:text-4xl">
                  <%= review.title || "Bez nadpisu" %>
                </h2>
                <span class="hidden text-4xl text-gray-400 sm:inline">|</span>
                <span class="text-2xl font-semibold text-white sm:text-3xl">
                  ⭐ <%= review.rating %>/10
                </span>
              </div>
              <p class="mt-3 text-lg font-medium text-[#00c950] sm:text-xl">
  <a href="/movies/<%= review.tmdb_movie_id %>" class="transition hover:opacity-80">
    <%= review.movieTitle %>
  </a>
</p>

              <p class="mt-5 max-w-5xl text-base leading-7 text-gray-300 sm:text-2xl sm:leading-8">
                <%= review.review_text %>
              </p>

              <% if (review.contains_spoilers) { %>
                <p class="mt-4 inline-block rounded-full bg-red-500/15 px-4 py-2 text-sm font-medium text-red-300">
                  Obsahuje spoilery
                </p>
              <% } %>

            <div class="mt-8 flex items-center justify-end gap-4 text-white">
  <% if (user && user.id !== review.user_id) { %>
    <form action="/reviews/<%= review.id %>/vote" method="POST">
      <input type="hidden" name="voteType" value="helpful" />
      <button class="flex items-center gap-2 text-2xl transition hover:text-gray-300">
        <span class="cursor-pointer">👍</span>
        <span class="text-xl"><%= review.helpful_count %></span>
      </button>
    </form>

    <form action="/reviews/<%= review.id %>/vote" method="POST">
      <input type="hidden" name="voteType" value="not_helpful" />
      <button class="flex items-center gap-2 text-2xl transition hover:text-gray-300">
        <span class="cursor-pointer">👎</span>
        <span class="text-xl"><%= review.not_helpful_count %></span>
      </button>
    </form>
  <% } else { %>
    <div class="flex items-center gap-2 text-2xl text-white/80">
      <span class="cursor-pointer">👍</span>
      <span class="text-xl"><%= review.helpful_count %></span>
    </div>

    <div class="flex items-center gap-2 text-2xl text-white/80">
      <span class="cursor-pointer">👎</span>
      <span class="text-xl"><%= review.not_helpful_count %></span>
    </div>
  <% } %>

  <button class="flex items-center gap-2 text-2xl transition hover:text-gray-300">
    <span>💬</span>
    <span class="text-xl">0</span>
  </button>
</div>
            </div>
          </div>
        </article>
      <% }) %>
    </section>
  </main>

  <%- include("partials/footer") %>

</body>
</html>