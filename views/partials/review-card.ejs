<article
  class="rounded-4xl bg-[#171c29] p-5 shadow-[0_10px_40px_rgba(0,0,0,0.35)] sm:p-7"
>
  <div class="flex flex-col gap-6 md:flex-row">
    <div class="w-full md:w-36">
      <a href="/movies/<%= review.tmdb_movie_id %>">
        <img
          src="<%= review.moviePoster %>"
          alt="Poster filmu <%= review.movieTitle %>"
          class="h-full w-full rounded-2xl object-cover"
        />
      </a>
    </div>

    <div class="flex-1">
      <div
        class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between"
      >
        <div class="flex items-center gap-3">
          <img
            src="<%= review.avatar_url || 'https://placehold.co/48x48?text=AV' %>"
            alt="Placeholder avatar používateľa <%= review.username %>"
            class="h-12 w-12 rounded-full object-cover"
          />
          <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
            <a
              href="/users/<%= encodeURIComponent(review.username) %>"
              class="text-lg font-semibold text-white transition hover:text-[#00c950]"
            >
              <%= review.username %>
            </a>
            <span class="text-lg text-gray-400">·</span>
            <span class="text-lg text-gray-400">
              <%= new Date(review.created_at).toLocaleDateString("sk-SK") %>
            </span>
          </div>
        </div>
      </div>

      <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2">
        <h2 class="text-3xl font-bold sm:text-4xl">
          <%= review.title || "Bez nadpisu" %>
        </h2>
        <span class="hidden text-4xl text-gray-400 sm:inline">|</span>
        <span class="text-2xl font-semibold text-white sm:text-3xl">
          ⭐ <%= review.rating %>/10
        </span>
      </div>
      <p class="mt-3 text-lg font-medium text-[#00c950] sm:text-xl">
        <a
          href="/movies/<%= review.tmdb_movie_id %>"
          class="transition hover:opacity-80"
        >
          <%= review.movieTitle %>
        </a>
      </p>

      <p
        class="mt-5 max-w-5xl text-base leading-7 text-gray-300 sm:text-2xl sm:leading-8"
      >
        <%= review.review_text %>
      </p>

      <% if (review.contains_spoilers) { %>
      <p
        class="mt-4 inline-block rounded-full bg-red-500/15 px-4 py-2 text-sm font-medium text-red-300"
      >
        Obsahuje spoilery
      </p>
      <% } %>

      <div
        class="mt-8 flex items-center justify-end gap-4 text-white"
        data-review-id="<%= review.id %>"
      >
        <% if (user && user.id !== review.user_id) { %>
        <button
          type="button"
          data-vote-button="helpful"
          class="flex items-center gap-2 text-2xl transition hover:text-gray-300"
        >
          <span class="cursor-pointer">👍</span>
          <span class="text-xl" data-helpful-count
            ><%= review.helpful_count %></span
          >
        </button>

        <button
          type="button"
          data-vote-button="not_helpful"
          class="flex items-center gap-2 text-2xl transition hover:text-gray-300"
        >
          <span class="cursor-pointer">👎</span>
          <span class="text-xl" data-not-helpful-count
            ><%= review.not_helpful_count %></span
          >
        </button>
        <% } else { %>
        <div class="flex items-center gap-2 text-2xl text-white/80">
          <span class="cursor-pointer">👍</span>
          <span class="text-xl" data-helpful-count
            ><%= review.helpful_count %></span
          >
        </div>

        <div class="flex items-center gap-2 text-2xl text-white/80">
          <span class="cursor-pointer">👎</span>
          <span class="text-xl" data-not-helpful-count
            ><%= review.not_helpful_count %></span
          >
        </div>
        <% } %>

        <a
          href="/reviews/<%= review.id %>/comments"
          class="flex items-center gap-2 text-2xl transition hover:text-gray-300"
        >
          <span>💬</span>
          <span class="text-xl"><%= review.comments_count %></span>
        </a>
      </div>
    </div>
  </div>
</article>
