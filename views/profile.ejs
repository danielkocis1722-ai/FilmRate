<!DOCTYPE html>
<html lang="sk">
  <head>
    <%- include("partials/head", { title: "Profil | FilmRate" }) %>
  </head>
  <body class="min-h-screen bg-[#05070d] text-white">
    <%- include("partials/navbar") %>

    <!-- HERO -->
    <section class="relative overflow-hidden">
      <div class="absolute inset-0">
        <img
          src="/images/hero-cinema.jpg"
          alt="Placeholder background profilu"
          class="h-full w-full object-cover"
        />
        <div class="absolute inset-0 bg-black/75"></div>
      </div>

      <div
        class="relative z-10 mx-auto max-w-7xl px-6 pb-16 pt-14 sm:pt-18 lg:pb-20"
      >
        <div
          class="flex flex-col gap-8 lg:flex-row lg:items-start lg:justify-between"
        >
          <div class="flex flex-col gap-6 sm:flex-row sm:items-start">
            <div class="shrink-0">
              <img
                src="<%= profileUser.avatar_url || 'https://placehold.co/170x170?text=Avatar' %>"
                alt="Avatar používateľa <%= profileUser.username %>"
                class="h-32 w-32 rounded-full object-cover ring-4 ring-white/10 sm:h-40 sm:w-40"
              />
            </div>

            <div class="pt-1">
              <div
                class="flex flex-col gap-3 lg:flex-row lg:flex-wrap lg:items-center"
              >
                <h1 class="text-4xl font-extrabold sm:text-5xl">
                  <%= profileUser.username %>
                </h1>

                <div
                  class="flex flex-wrap items-center gap-x-5 gap-y-2 text-lg text-gray-300 sm:text-2xl"
                >
                  <span
                    >•
                    <%= stats.reviewCount %>
                    recenzií</span
                  >
                  <span
                    ><%= stats.averageRating %>
                    priemer</span
                  >
                  <span
                    ><%= stats.helpfulCount %>
                    👍</span
                  >
                </div>
              </div>

              <p
                class="mt-5 max-w-2xl text-lg leading-8 text-gray-200 sm:text-2xl sm:leading-9"
              >
                <% if (profileUser.bio) { %> <%= profileUser.bio %> <% } else if
                (isOwnProfile) { %> Toto je tvoj profil vo FilmRate. <% } else {
                %> Profil používateľa <%= profileUser.username %> vo FilmRate.
                <% } %>
              </p>

              <div class="mt-8 flex flex-wrap gap-4">
                <% if (isOwnProfile) { %>
                <a
                  href="/profile/edit"
                  class="inline-flex items-center justify-center rounded-lg bg-[#738b58] px-8 py-4 text-xl font-semibold text-white transition hover:bg-[#829d64]"
                >
                  Upraviť profil
                </a>
                <% } %>

                <a
                  href="#reviews"
                  class="inline-flex items-center justify-center rounded-lg border border-white/20 bg-white/5 px-8 py-4 text-xl font-medium text-white transition hover:bg-white/10"
                >
                  <% if (isOwnProfile) { %>
                  Moje recenzie
                  <% } else { %>
                  Recenzie používateľa
                  <% } %>
                </a>
              </div>
            </div>
          </div>

          <aside
            class="w-full max-w-90 rounded-4xl bg-[#171c29]/90 p-6 shadow-[0_10px_40px_rgba(0,0,0,0.35)] backdrop-blur-sm"
          >
            <h2 class="text-2xl font-bold">O používateľovi</h2>

            <div class="mt-6 space-y-4 text-lg text-gray-300">
              <div class="flex items-center justify-between gap-4">
                <span>Obľúbený žáner</span>
                <span class="font-medium text-white">
                  <%= profileUser.favorite_genre || 'Neuvedené' %>
                </span>
              </div>
              <div class="flex items-center justify-between gap-4">
                <span>Používateľské meno</span>
                <span class="font-medium text-white"
                  ><%= profileUser.username %></span
                >
              </div>
              <% if (isOwnProfile) { %>
              <div class="flex items-center justify-between gap-4">
                <span>E-mail</span>
                <span class="font-medium text-white"
                  ><%= profileUser.email %></span
                >
              </div>
              <% } %>

              <div class="flex items-center justify-between gap-4">
                <span>Rola</span>
                <span class="font-medium capitalize text-white"
                  ><%= profileUser.role %></span
                >
              </div>

              <div class="flex items-center justify-between gap-4">
                <span>Registrovaný</span>
                <span class="font-medium text-white">
                  <%= new
                  Date(profileUser.created_at).toLocaleDateString("sk-SK") %>
                </span>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- TABS -->
    <section class="bg-[#07101d] px-6 pt-8">
      <div class="mx-auto max-w-7xl">
        <div class="flex flex-wrap gap-3 border-b border-white/10 pb-5">
          <button
            class="rounded-full bg-white px-6 py-3 text-lg font-semibold text-black"
          >
            Recenzie
          </button>
          <button
            class="rounded-full border border-white/20 bg-white/5 px-6 py-3 text-lg font-medium text-white transition hover:bg-white/10"
          >
            Obľúbené
          </button>
          <button
            class="rounded-full border border-white/20 bg-white/5 px-6 py-3 text-lg font-medium text-white transition hover:bg-white/10"
          >
            Watchlist
          </button>
        </div>
      </div>
    </section>

    <!-- REVIEWS -->
    <section on id="reviews" class="bg-[#07101d] px-6 py-12 sm:py-14">
      <div class="mx-auto max-w-7xl">
        <h2 class="text-5xl font-extrabold sm:text-6xl">Recenzie</h2>

        <% if (reviews.length === 0) { %>
        <div
          class="mt-10 rounded-4xl bg-[#171c29] p-8 text-center shadow-[0_10px_40px_rgba(0,0,0,0.35)]"
        >
          <h3 class="text-3xl font-bold">Zatiaľ si nepridal žiadnu recenziu</h3>
          <p class="mt-4 text-lg text-gray-300">
            Skús napísať svoju prvú recenziu.
          </p>

          <div class="mt-8">
            <a
              href="/reviews/create"
              class="inline-flex items-center justify-center rounded-lg bg-[#738b58] px-8 py-4 text-xl font-semibold text-white transition hover:bg-[#829d64]"
            >
              Vytvoriť recenziu
            </a>
          </div>
        </div>
        <% } %>

        <div class="mt-10 space-y-8">
          <% reviews.forEach(review => { %>
          <%- include("partials/review-card", { review, user }) %>
          <% }) %>
        </div>
      </div>
    </section>

    <%- include("partials/footer") %>
  </body>
</html>
