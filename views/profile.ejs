<!DOCTYPE html>
<html lang="sk">
<head>
  <%- include("partials/head", { title: "Profil | FilmRate" }) %>
</head>
<body class="min-h-screen bg-[#05070d] text-white">

  <%- include("partials/navbar") %>

  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/hero-cinema.jpg"
        alt="Placeholder background profilu"
        class="h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-black/75"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-6 pb-16 pt-14 sm:pt-18 lg:pb-20">
      <div class="flex flex-col gap-8 lg:flex-row lg:items-start lg:justify-between">
        <div class="flex flex-col gap-6 sm:flex-row sm:items-start">
          <div class="shrink-0">
            <img
              src="https://placehold.co/170x170?text=Avatar"
              alt="Placeholder avatar používateľa <%= profileUser.username %>"
              class="h-32 w-32 rounded-full object-cover ring-4 ring-white/10 sm:h-40 sm:w-40"
            />
          </div>

          <div class="pt-1">
            <div class="flex flex-col gap-3 lg:flex-row lg:flex-wrap lg:items-center">
              <h1 class="text-4xl font-extrabold sm:text-5xl"><%= profileUser.username %></h1>

              <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-lg text-gray-300 sm:text-2xl">
                <span>• <%= stats.reviewCount %> recenzií</span>
                <span><%= stats.averageRating %> priemer</span>
                <span><%= stats.helpfulCount %> 👍</span>
              </div>
            </div>

            <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-200 sm:text-2xl sm:leading-9">
              Toto je tvoj profil vo FilmRate.
            </p>

            <div class="mt-8 flex flex-wrap gap-4">
              <button
                type="button"
                class="inline-flex items-center justify-center rounded-lg bg-[#738b58] px-8 py-4 text-xl font-semibold text-white transition hover:bg-[#829d64]"
              >
                Upraviť profil
              </button>

              <a
                href="#reviews"
                class="inline-flex items-center justify-center rounded-lg border border-white/20 bg-white/5 px-8 py-4 text-xl font-medium text-white transition hover:bg-white/10"
              >
                Moje recenzie
              </a>
            </div>
          </div>
        </div>

        <aside class="w-full max-w-90 rounded-4xl bg-[#171c29]/90 p-6 shadow-[0_10px_40px_rgba(0,0,0,0.35)] backdrop-blur-sm">
          <h2 class="text-2xl font-bold">O používateľovi</h2>

          <div class="mt-6 space-y-4 text-lg text-gray-300">
            <div class="flex items-center justify-between gap-4">
              <span>Používateľské meno</span>
              <span class="font-medium text-white"><%= profileUser.username %></span>
            </div>

            <div class="flex items-center justify-between gap-4">
              <span>E-mail</span>
              <span class="font-medium text-white"><%= profileUser.email %></span>
            </div>

            <div class="flex items-center justify-between gap-4">
              <span>Rola</span>
              <span class="font-medium capitalize text-white"><%= profileUser.role %></span>
            </div>

            <div class="flex items-center justify-between gap-4">
              <span>Registrovaný</span>
              <span class="font-medium text-white">
                <%= new Date(profileUser.created_at).toLocaleDateString("sk-SK") %>
              </span>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- TABS -->
  <section class="bg-[#07101d] px-6 pt-8">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-wrap gap-3 border-b border-white/10 pb-5">
        <button class="rounded-full bg-white px-6 py-3 text-lg font-semibold text-black">
          Recenzie
        </button>
        <button class="rounded-full border border-white/20 bg-white/5 px-6 py-3 text-lg font-medium text-white transition hover:bg-white/10">
          Obľúbené
        </button>
        <button class="rounded-full border border-white/20 bg-white/5 px-6 py-3 text-lg font-medium text-white transition hover:bg-white/10">
          Watchlist
        </button>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section id="reviews" class="bg-[#07101d] px-6 py-12 sm:py-14">
    <div class="mx-auto max-w-7xl">
      <h2 class="text-5xl font-extrabold sm:text-6xl">Recenzie</h2>

      <% if (reviews.length === 0) { %>
        <div class="mt-10 rounded-4xl bg-[#171c29] p-8 text-center shadow-[0_10px_40px_rgba(0,0,0,0.35)]">
          <h3 class="text-3xl font-bold">Zatiaľ si nepridal žiadnu recenziu</h3>
          <p class="mt-4 text-lg text-gray-300">
            Skús napísať svoju prvú recenziu.
          </p>

          <div class="mt-8">
            <a
              href="/reviews/create"
              class="inline-flex items-center justify-center rounded-lg bg-[#738b58] px-8 py-4 text-xl font-semibold text-white transition hover:bg-[#829d64]"
            >
              Vytvoriť recenziu
            </a>
          </div>
        </div>
      <% } %>

      <div class="mt-10 space-y-8">
        <% reviews.forEach(review => { %>
          <article class="rounded-4xl bg-[#171c29] p-6 shadow-[0_10px_40px_rgba(0,0,0,0.35)] sm:p-8">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
              <div class="flex items-center gap-3">
                <img
                  src="https://placehold.co/48x48?text=AV"
                  alt="Placeholder avatar používateľa <%= review.username %>"
                  class="h-12 w-12 rounded-full object-cover"
                />
                <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                  <span class="text-xl font-semibold text-white"><%= review.username %></span>
                  <span class="text-xl text-gray-400">·</span>
                  <span class="text-xl text-gray-400">
                    <%= new Date(review.created_at).toLocaleDateString("sk-SK") %>
                  </span>
                </div>
              </div>

              <div class="text-left sm:text-right">
                <span class="text-3xl font-semibold text-white">⭐ <%= review.rating %>/10</span>
              </div>
            </div>

            <% if (review.title) { %>
              <h3 class="mt-6 text-2xl font-bold sm:text-3xl"><%= review.title %></h3>
            <% } %>

            <p class="mt-3 text-lg font-medium text-[#00c950] sm:text-xl">
  <a href="/movies/<%= review.tmdb_movie_id %>" class="transition hover:opacity-80">
    <%= review.movieTitle %>
  </a>
</p>

            <p class="mt-6 text-base leading-7 text-gray-300 sm:text-2xl sm:leading-8">
              <%= review.review_text %>
            </p>

            <% if (review.contains_spoilers) { %>
              <p class="mt-4 inline-block rounded-full bg-red-500/15 px-4 py-2 text-sm font-medium text-red-300">
                Obsahuje spoilery
              </p>
            <% } %>

            <div class="mt-8 flex items-center justify-end gap-6 text-white">
  <div class="flex items-center gap-2 text-2xl text-white/80">
    <span class="cursor-pointer">👍</span>
    <span class="text-xl"><%= review.helpful_count %></span>
  </div>

  <div class="flex items-center gap-2 text-2xl text-white/80">
    <span class="cursor-pointer">👎</span>
    <span class="text-xl"><%= review.not_helpful_count %></span>
  </div>

  <div class="flex items-center gap-2 text-2xl text-white/80">
    <span>💬</span>
    <span class="text-xl">0</span>
  </div>
            </div>
          </article>
        <% }) %>
      </div>
    </div>
  </section>

  <%- include("partials/footer") %>

</body>
</html>